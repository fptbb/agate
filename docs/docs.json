{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Agate",
  "logo": "https://gitlab.com/uploads/-/system/project/avatar/76001048/fp-logo.png",
  "colors": {
    "primary": "#fb6c24",
    "light": "#fba224",
    "dark": "#2f2e6d"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "GitLab",
      "href": "https://gitlab.com/fpsys/agate"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "introduction",
          "quickstart",
          "verification"
        ]
      },
      {
        "group": "Build from Source",
        "pages": [
          "building/prerequisites",
          "building/build-image",
          "building/build-iso"
        ]
      },
      {
        "group": "Configuration",
        "pages": [
          "configuration/recipes",
          "configuration/packages",
          "configuration/theming"
        ]
      },
      {
        "group": "Helper Scripts",
        "pages": [
          "scripts/dotfiles",
          "scripts/security",
          "scripts/development"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/justfile",
          "reference/acknowledgements"
        ]
      }
    ]
  },
  "description": "Agate: fp-os",
  "favicon": "https://gitlab.com/uploads/-/system/project/avatar/76001048/fp-logo.png",
  "appearance": {
    "default": "dark"
  },
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  },
  "styling": {
    "latex": true
  },
  "icons": {
    "library": "lucide"
  }
}
