#!/usr/bin/env bash
set -euo pipefail

STATE_VERSION=1
STATE_FILE="/etc/agate/dev-groups-version"
CURRENT_VERSION=$(cat "$STATE_FILE" 2>/dev/null || echo 0)

if [[ "$CURRENT_VERSION" == "$STATE_VERSION" ]]; then
    exit 0
fi

mkdir -p /etc/agate

append_group() {
    local group_name="$1"
    if ! grep -q "^${group_name}:" /etc/group; then
        grep "^${group_name}:" /usr/lib/group >> /etc/group
    fi
}

append_group docker
append_group libvirt
append_group dialout

mapfile -t wheel_members < <(getent group wheel | cut -d ':' -f 4 | tr ',' '\n')
for user in "${wheel_members[@]}"; do
    [[ -n "$user" ]] || continue
    usermod -aG docker "$user"
    usermod -aG libvirt "$user"
    usermod -aG dialout "$user"
done

printf '%s\n' "$STATE_VERSION" > "$STATE_FILE"
